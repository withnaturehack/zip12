# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — use your Supabase URL or any local Postgres DB
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing secret — any long random string works
JWT_SECRET=your-secret-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# API server port (defaults to 8080)
PORT=8080

# Set to "true" to auto-seed demo accounts on first startup
AUTO_SEED=false
