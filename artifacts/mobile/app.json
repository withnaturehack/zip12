{
  "expo": {
    "name": "CampusOps",
    "slug": "mobile",
    "owner": "karzo15",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/paradox-logo.jpg",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.iitm.campusops"
    },
    "android": {
      "package": "in.iitm.campusops",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/paradox-logo.jpg",
        "backgroundColor": "#ffffff"
      },
      "allowBackup": false
    },
    "web": {
      "favicon": "./assets/images/paradox-logo.jpg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://localhost"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "https://zip-12--vpahaddevbhoomi.replit.app/api",
      "router": {
        "origin": "https://zip-12--vpahaddevbhoomi.replit.app",
        "headOrigin": "https://zip-12--vpahaddevbhoomi.replit.app"
      },
      "eas": {
        "projectId": "d15d6c97-8294-43d8-adbc-f874fb918911"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d15d6c97-8294-43d8-adbc-f874fb918911"
    }
  }
}
